# ---------------------------------------------------------------------------
# PoiskKino provider configuration. Copy to `.env` and fill in your token.
# All variables are prefixed with POISKKINO_ and read at startup.
# ---------------------------------------------------------------------------

# REQUIRED. Your PoiskKino API token (get one from https://t.me/poiskkinodev_bot).
# Never commit the real token.
POISKKINO_API_TOKEN=your-token-here

# PoiskKino API base URL (rarely needs changing).
POISKKINO_API_BASE=https://api.poiskkino.dev

# --- HTTP server ---
# The Plex provider API has NO authentication yet, so it must NOT be exposed
# publicly. Default bind is 127.0.0.1 (safe). Leave POISKKINO_HOST unset for
# Docker — the image binds 0.0.0.0 inside the container and the host port is
# published to 127.0.0.1 by the compose file. Only set it for a native run.
# POISKKINO_HOST=127.0.0.1
POISKKINO_PORT=8000

# --- Provider identity (shown in Plex, must be unique on the server) ---
POISKKINO_IDENTIFIER_PREFIX=tv.plex.agents.custom.hackercb.poiskkino
POISKKINO_TITLE=PoiskKino (Кинопоиск)

# --- What the provider contributes (rating is always on) ---
POISKKINO_WRITE_POSTER=true
POISKKINO_WRITE_SUMMARY=true
POISKKINO_WRITE_ART=true
POISKKINO_WRITE_GENRES=false

# Which built-in Plex rating badge the Kinopoisk score rides under.
# Plex has NO Kinopoisk icon; allowed values: imdb, themoviedb, rottentomatoes_ripe, rottentomatoes_upright.
POISKKINO_RATING_IMAGE=imdb

# --- Matching ---
# Minimum title-similarity score (0..1) to accept a text-search fallback match.
POISKKINO_MATCH_THRESHOLD=0.6

# --- Caching (reduces PoiskKino requests; 5000/day quota) ---
POISKKINO_CACHE_TTL_SECONDS=86400
POISKKINO_CACHE_MAX_ENTRIES=4096

# --- HTTP client ---
POISKKINO_REQUEST_TIMEOUT=20.0

# --- Logging ---
POISKKINO_LOG_LEVEL=INFO
